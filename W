      </div>
      <div class="quiz-score-badge">النقاط: <span id="currentScore">0</span></div>
    </div>

    <div id="quizBody">
      <div class="quiz-progress-bar">
        <div class="quiz-progress-fill" id="progressFill" style="width:0%"></div>
      </div>
      <div style="font-size:0.82rem;color:#aaa;margin-bottom:16px" id="qCounter">سؤال 0 من 0</div>
      <div class="question-text" id="questionText">اضغط على أحد المواضيع أعلاه لبدء المسابقة</div>
      <ul class="options-list" id="optionsList"></ul>
      <div class="quiz-feedback" id="quizFeedback"></div>
      <button class="btn-next" id="btnNext" onclick="nextQuestion()">السؤال التالي ←</button>
    </div>

    <div class="quiz-result" id="quizResult">
      <span class="result-emoji" id="resultEmoji">🎉</span>
      <div class="result-score" id="resultScore">0 / 0</div>
      <div class="result-text" id="resultText">أحسنت!</div>
      <button class="btn-restart" onclick="restartQuiz()">🔄 إعادة المسابقة</button>
    </div>
  </div>
</div>

<hr class="section-divider">

<!-- ===== LEADERBOARD SECTION ===== -->
<div class="section" id="leaderboard">
  <span class="section-label">المتنافسون</span>
  <div class="section-title">🏅 لوحة المتصدرين</div>

  <div class="leaderboard-section">
    <div class="leaderboard-header">
      <div class="leaderboard-title">🥇 أفضل الممرضين</div>
      <button onclick="clearLeaderboard()" style="padding:8px 16px;background:rgba(231,111,81,0.1);color:var(--danger);border:1px solid var(--danger);border-radius:20px;font-size:0.8rem;font-family:'Cairo',sans-serif;font-weight:700;cursor:pointer">🗑️ مسح الكل</button>
    </div>
    <div id="leaderboardList"></div>
  </div>
</div>

<footer>
  صُنع بـ ❤️ لطلاب وممرضي <span>العالم العربي</span> — بوابة التمريض التعليمية التفاعلية
</footer>

<script>
// ======= DATA ========
const quizData = {
  injections: [
    { q:"ما الزاوية الصحيحة للحقن العضلي (IM)؟", opts:["15 درجة","45 درجة","90 درجة","30 درجة"], ans:2, exp:"الحقن العضلي يُعطى بزاوية 90 درجة (عمودي على الجلد) للوصول إلى عمق العضلة." },
    { q:"أي من هذه الأدوية يُعطى بالحقن تحت الجلد (SC)؟", opts:["الأمبيسيلين","الأنسولين","المورفين","سلبامول"], ans:1, exp:"الأنسولين يُعطى تحت الجلد لضمان الامتصاص البطيء والمنتظم في الطبقة الدهنية." },
    { q:"ما أصغر gauge تُستخدم لحقن داخل الجلد (ID)؟", opts:["18G","21G","25G","26-27G"], ans:3, exp:"الحقن داخل الجلد يستخدم إبرة 26-27 gauge وهي الأدق والأصغر لأن الكمية 0.1 مل فقط." },
    { q:"ما الغرض الأساسي من اختبار Mantoux؟", opts:["قياس سكر الدم","كشف السل","اختبار حساسية البنسلين","إعطاء لقاح الإنفلونزا"], ans:1, exp:"اختبار Mantoux هو حقنة داخل الجلد (ID) تُستخدم للكشف عن الإصابة بالسل. تُقرأ نتيجتها بعد 48-72 ساعة." },
    { q:"في أي موضع يُفضل الحقن العضلي للرضع والأطفال الصغار؟", opts:["الألوية الكبرى","العضلة الدالية","Vastus Lateralis (الرباعية الجانبية)","الفخذ الأمامي"], ans:2, exp:"يُفضل Vastus Lateralis للرضع لأن عضلتهم الدالية صغيرة جداً والألوية قد تصيب العصب الوركي." },
    { q:"ما الوصف الصحيح لتقنية Z-track في الحقن العضلي؟", opts:["حقن بزاوية 45 درجة","سحب الجلد جانباً قبل الحقن ثم إفلاته بعده","الدلك بقوة بعد الحقن","استخدام إبرة أطول من المعتاد"], ans:1, exp:"Z-track تعني سحب الجلد جانباً 2-3 سم، الحقن، ثم إفلاته — مما يمنع تسرب الدواء للنسيج تحت الجلد." },
    { q:"ما الحجم الأقصى للحقن في العضلة الدالية (Deltoid)؟", opts:["5 مل","3 مل","2 مل","10 مل"], ans:2, exp:"العضلة الدالية صغيرة نسبياً، الحجم الأقصى 2 مل. أما الألوية فتتحمل حتى 5 مل." },
    { q:"أي نوع حقن يُستخدم في حالات الطوارئ عندما يتعذر الوصول الوريدي؟", opts:["الحقن تحت الجلد","الحقن داخل الجلد","الحقن داخل العظم (IO)","الحقن فوق الجافية"], ans:2, exp:"الحقن داخل العظم (IO) يُستخدم طارئاً — خاصة في الإنعاش القلبي الرئوي — عندما يتعذر إيجاد وصول وريدي." },
  ],
  vitals: [
    { q:"ما القيمة الطبيعية لضغط الدم عند البالغين؟", opts:["150/90 mmHg","90/60 mmHg","120/80 mmHg","140/70 mmHg"], ans:2, exp:"120/80 هي القيمة الطبيعية الكلاسيكية. 121-139/81-89 تُعتبر قبل ارتفاع الضغط، فوق 140/90 ارتفاع." },
    { q:"مريض معدل قلبه 110 نبضة/دقيقة — ما هذه الحالة؟", opts:["Bradycardia","Tachycardia","Normosinus","Fibrillation"], ans:1, exp:"Tachycardia = معدل قلب فوق 100/دقيقة. Bradycardia = أقل من 60/دقيقة." },
    { q:"ما أدنى قيمة SpO₂ تستدعي التدخل الفوري بالأكسجين؟", opts:["98%","95%","90%","85%"], ans:2, exp:"SpO₂ أقل من 90% يعتبر حرجاً يستدعي إعطاء الأكسجين فوراً. 95-100% طبيعي." },
    { q:"أي مكان قياس الحرارة يعطي أعلى قراءة؟", opts:["الفم","الإبط","الأذن","المستقيم (الشرجي)"], ans:3, exp:"القياس الشرجي (المستقيم) يعطي أعلى قراءة لأنه أقرب لدرجة الحرارة الجوهرية للجسم بـ 0.5°C تقريباً." },
    { q:"ما معدل التنفس الطبيعي عند البالغ؟", opts:["6-10","12-20","20-30","8-15"], ans:1, exp:"المعدل الطبيعي 12-20 نفس/دقيقة. أقل من 12 = Bradypnea. أكثر من 20 = Tachypnea." },
    { q:"ما درجة الحرارة التي تُعرَّف عندها الحمى (Fever) عند البالغ؟", opts:["فوق 37°C","فوق 37.5°C","فوق 38°C","فوق 39°C"], ans:2, exp:"الحمى تُعرَّف عموماً بارتفاع الحرارة فوق 38°C (100.4°F). فوق 40°C تُعتبر hyperpyrexia." },
    { q:"أي جهاز يُستخدم لقياس SpO₂؟", opts:["Sphygmomanometer","Stethoscope","Pulse Oximeter","Thermometer"], ans:2, exp:"Pulse Oximeter أو مقياس الأكسجين النبضي — يُوضع على الإصبع ويقرأ تشبع الأكسجين بالدم بدون سحب دم." },
    { q:"مريض ضغطه 85/55 mmHg — ما التشخيص المحتمل؟", opts:["Hypertension","Hypotension","Tachycardia","Bradypnea"], ans:1, exp:"Hypotension = انخفاض ضغط الدم. القيمة الطبيعية الدنيا 90/60. 85/55 تستدعي تدخلاً سريعاً." },
  ],
  mixed: []
};
quizData.mixed = [...quizData.injections, ...quizData.vitals].sort(() => Math.random()-0.5);

let currentUser = '';
let currentTopic = 'injections';
let currentQs = [];
let qIndex = 0;
let score = 0;
let answered = false;

// ======= NAME GATE ========
function enterSite() {
  const name = document.getElementById('userName').value.trim();
  if (!name) { document.getElementById('userName').style.borderColor='#e76f51'; return; }
  currentUser = name;
  document.getElementById('nameGate').style.display = 'none';
  showFlash(`مرحباً ${name}! 🎉`);
  renderLeaderboard();
}

function showFlash(msg) {
  const el = document.getElementById('flashMsg');
  el.textContent = msg;
  el.style.display = 'block';
  setTimeout(()=> el.style.display='none', 2500);
}

// ======= TABS ========
function openTab(evt, id) {
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  evt.target.classList.add('active');
}

// ======= INJECTION DETAILS ========
function toggleDetails(btn) {
  const details = btn.nextElementSibling;
  details.classList.toggle('open');
  btn.textContent = details.classList.contains('open') ? '🔼 أخفِ التفاصيل' : '📖 تفاصيل أكثر';
}

// ======= VITAL CHECKER ========
function checkVitals() {
  const hr = parseFloat(document.getElementById('vHR').value);
  const rr = parseFloat(document.getElementById('vRR').value);
  const temp = parseFloat(document.getElementById('vTemp').value);
  const sbp = parseFloat(document.getElementById('vSBP').value);
  const spo2 = parseFloat(document.getElementById('vSPO2').value);

  let issues = [];
  let warnings = [];

  if (!isNaN(hr)) {
    if (hr < 60) issues.push(`❤️ معدل القلب ${hr} — Bradycardia (بطيء)`);
    else if (hr > 100) issues.push(`❤️ معدل القلب ${hr} — Tachycardia (متسارع)`);
  }
  if (!isNaN(rr)) {
    if (rr < 12) issues.push(`🫁 التنفس ${rr} — Bradypnea (بطيء)`);
    else if (rr > 20) issues.push(`🫁 التنفس ${rr} — Tachypnea (متسارع)`);
  }
  if (!isNaN(temp)) {
    if (temp < 36) issues.push(`🌡️ الحرارة ${temp}°C — Hypothermia (انخفاض)`);
    else if (temp > 38) issues.push(`🌡️ الحرارة ${temp}°C — Fever (حمى)`);
    else if (temp > 40) issues.push(`🌡️ الحرارة ${temp}°C — Hyperpyrexia (حرجة)`);
  }
  if (!isNaN(sbp)) {
    if (sbp < 90) issues.push(`💊 الضغط الانقباضي ${sbp} — Hypotension (منخفض)`);
    else if (sbp > 140) issues.push(`💊 الضغط الانقباضي ${sbp} — Hypertension (مرتفع)`);
  }
  if (!isNaN(spo2)) {
    if (spo2 < 90) issues.push(`🩺 SpO₂ ${spo2}% — طارئ! أعطِ أكسجين فوراً`);
    else if (spo2 < 95) warnings.push(`🩺 SpO₂ ${spo2}% — منخفض، راقب المريض`);
  }

  const el = document.getElementById('vitalResult');
  el.style.display = 'block';

  if (issues.length > 0) {
    el.className = 'vital-result abnormal';
    el.innerHTML = `<strong>⚠️ قيم غير طبيعية — يستدعي التدخل:</strong><br>${issues.join('<br>')}${warnings.length?'<br>'+warnings.join('<br>'):''}`;
  } else if (warnings.length > 0) {
    el.className = 'vital-result abnormal';
    el.innerHTML = `<strong>⚡ تنبيه:</strong><br>${warnings.join('<br>')}`;
  } else {
    el.className = 'vital-result normal';
    el.innerHTML = `<strong>✅ جميع القيم المُدخلة ضمن المعدل الطبيعي</strong><br>المريض في حالة مستقرة.`;
  }
}

// ======= QUIZ ========
function selectTopic(topic, btn) {
  currentTopic = topic;
  document.querySelectorAll('.quiz-topic-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  startQuiz();
}

function startQuiz() {
  const pool = [...quizData[currentTopic]].sort(() => Math.random()-0.5);
  currentQs = pool.slice(0, Math.min(8, pool.length));
  qIndex = 0; score = 0;
  document.getElementById('currentScore').textContent = 0;
  document.getElementById('quizResult').classList.remove('show');
  document.getElementById('quizBody').style.display = 'block';
  showQuestion();
}

function showQuestion() {
  const q = currentQs[qIndex];
  const total = currentQs.length;
  document.getElementById('progressFill').style.width = `${(qIndex/total)*100}%`;
  document.getElementById('qCounter').textContent = `سؤال ${qIndex+1} من ${total}`;
  document.getElementById('questionText').textContent = q.q;
  document.getElementById('quizFeedback').className = 'quiz-feedback';
  document.getElementById('quizFeedback').textContent = '';
  document.getElementById('btnNext').classList.remove('show');
  answered = false;

  const list = document.getElementById('optionsList');
  list.innerHTML = '';
  q.opts.forEach((opt, i) => {
    const li = document.createElement('li');
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.textContent = opt;
    btn.onclick = () => selectAnswer(i, q, btn);
    li.appendChild(btn);
    list.appendChild(li);
  });
}

function selectAnswer(chosen, q, btn) {
  if (answered) return;
  answered = true;
  const correct = q.ans;
  const allBtns = document.querySelectorAll('.option-btn');
  allBtns.forEach(b => b.disabled = true);
  allBtns[correct].classList.add('correct');

  const fb = document.getElementById('quizFeedback');
  if (chosen === correct) {
    score++;
    document.getElementById('currentScore').textContent = score;
    btn.classList.add('correct');
    fb.className = 'quiz-feedback correct show';
    fb.textContent = `✅ صحيح! ${q.exp}`;
  } else {
    btn.classList.add('wrong');
    fb.className = 'quiz-feedback wrong show';
    fb.textContent = `❌ خطأ. ${q.exp}`;
  }

  document.getElementById('btnNext').classList.add('show');
}

function nextQuestion() {
  qIndex++;
  if (qIndex >= currentQs.length) {
    endQuiz();
  } else {
    showQuestion();
  }
}

function endQuiz() {
  document.getElementById('quizBody').style.display = 'none';
  const res = document.getElementById('quizResult');
  res.classList.add('show');
  const total = currentQs.length;
  const pct = Math.round((score/total)*100);
  document.getElementById('resultScore').textContent = `${score} / ${total}`;

  let emoji, text;
  if (pct >= 90) { emoji='🏆'; text='ممتاز! أنت ممرض نجم ⭐'; }
  else if (pct >= 70) { emoji='🎉'; text='جيد جداً! استمر في التعلم'; }
  else if (pct >= 50) { emoji='👍'; text='جيد، راجع الشرح مرة أخرى'; }
  else { emoji='📚'; text='لا بأس، المثابرة هي المفتاح!'; }

  document.getElementById('resultEmoji').textContent = emoji;
  document.getElementById('resultText').textContent = text;

  // Save to leaderboard
  saveScore(currentUser, score, total, currentTopic);
  renderLeaderboard();
}

function restartQuiz() {
  document.getElementById('quizResult').classList.remove('show');
  document.getElementById('quizBody').style.display = 'block';
  startQuiz();
}

// ======= LEADERBOARD ========
function saveScore(name, score, total, topic) {
  const key = 'nursing_leaderboard';
  let board = JSON.parse(localStorage.getItem(key) || '[]');
  board.push({
    name,
    score,
    total,
    topic: topic === 'injections' ? '💉 الحقن' : topic === 'vitals' ? '❤️ علامات حيوية' : '🎲 مختلطة',
    pct: Math.round((score/total)*100),
    date: new Date().toLocaleDateString('ar-EG')
  });
  board.sort((a,b) => b.pct - a.pct || b.score - a.score);
  localStorage.setItem(key, JSON.stringify(board.slice(0,50)));
}

function renderLeaderboard() {
  const key = 'nursing_leaderboard';
  const board = JSON.parse(localStorage.getItem(key) || '[]');
  const el = document.getElementById('leaderboardList');

  if (board.length === 0) {
    el.innerHTML = '<div class="lb-empty">🎯 لا يوجد سجلات بعد — أكمل مسابقة لتظهر هنا!</div>';
    return;
  }

  el.innerHTML = board.slice(0,15).map((entry, i) => {
    const rank = i+1;
    const medals = ['🥇','🥈','🥉'];
    const medal = medals[i] || `#${rank}`;
    const cls = rank <= 3 ? `rank-${rank}` : '';
    return `<div class="lb-row ${cls}">
      <div class="lb-rank">${medal}</div>
      <div style="flex:1">
        <div class="lb-name">${escHtml(entry.name)}</div>
        <div class="lb-topic">${entry.topic}</div>
      </div>
      <div>
        <div class="lb-score">${entry.score}/${entry.total}</div>
        <div class="lb-date">${entry.pct}% · ${entry.date}</div>
      </div>
    </div>`;
  }).join('');
}

function clearLeaderboard() {
  if (!confirm('هل تريد مسح جميع السجلات؟')) return;
  localStorage.removeItem('nursing_leaderboard');
  renderLeaderboard();
}

function escHtml(s) {
  return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// ======= INIT ========
window.onload = () => {
  renderLeaderboard();
  // pre-load quiz display
  document.getElementById('questionText').textContent = 'اضغط على أحد مواضيع المسابقة أعلاه لتبدأ!';
};
</script>
</body>
</html>
