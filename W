<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>بوابة التمريض التعليمية</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700&display=swap');

  :root {
    --primary: #0a5c7a;
    --accent: #00b4d8;
    --gold: #f4a261;
    --bg: #f0f7fa;
    --card: #ffffff;
    --dark: #062d3e;
    --text: #1a3a47;
    --success: #2a9d8f;
    --danger: #e76f51;
    --light-accent: #caf0f8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Cairo', sans-serif;
    background: var(--bg);
    color: var(--text);
    overflow-x: hidden;
  }

  /* ===== HERO ===== */
  .hero {
    background: linear-gradient(135deg, var(--dark) 0%, var(--primary) 60%, #0077a8 100%);
    color: white;
    padding: 0;
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(0,180,216,0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(0,180,216,0.1) 0%, transparent 40%);
    pointer-events: none;
  }

  .hero-pulse {
    position: absolute;
    top: 50%;
    left: 10%;
    transform: translateY(-50%);
    opacity: 0.06;
    font-size: 320px;
    line-height: 1;
    pointer-events: none;
    animation: heartbeat 1.5s ease-in-out infinite;
  }

  @keyframes heartbeat {
    0%, 100% { transform: translateY(-50%) scale(1); }
    50% { transform: translateY(-50%) scale(1.05); }
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 40px;
    background: rgba(0,0,0,0.2);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(0,180,216,0.3);
  }

  .logo {
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-links {
    display: flex;
    gap: 6px;
    list-style: none;
    flex-wrap: wrap;
  }

  .nav-links a {
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    padding: 7px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.2s;
  }

  .nav-links a:hover {
    background: rgba(0,180,216,0.3);
    color: white;
  }

  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 60px 20px;
    position: relative;
    z-index: 2;
  }

  .hero-badge {
    background: rgba(0,180,216,0.2);
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 6px 20px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 24px;
    display: inline-block;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 20px;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  .hero h1 span { color: var(--accent); }

  .hero p {
    font-size: 1.1rem;
    opacity: 0.85;
    max-width: 580px;
    line-height: 1.8;
    margin-bottom: 40px;
    font-family: 'Tajawal', sans-serif;
  }

  /* ===== NAME GATE ===== */
  #nameGate {
    position: fixed;
    inset: 0;
    background: linear-gradient(135deg, var(--dark), var(--primary));
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .name-gate-card {
    background: rgba(255,255,255,0.07);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(0,180,216,0.4);
    border-radius: 24px;
    padding: 50px 40px;
    text-align: center;
    max-width: 480px;
    width: 100%;
    color: white;
  }

  .name-gate-icon {
    font-size: 70px;
    margin-bottom: 20px;
    animation: heartbeat 1.5s ease-in-out infinite;
    display: block;
  }

  .name-gate-card h2 {
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 10px;
    color: var(--accent);
  }

  .name-gate-card p {
    opacity: 0.8;
    margin-bottom: 30px;
    font-family: 'Tajawal', sans-serif;
    line-height: 1.7;
  }

  .name-gate-card input {
    width: 100%;
    padding: 16px 20px;
    border-radius: 14px;
    border: 2px solid rgba(0,180,216,0.4);
    background: rgba(255,255,255,0.1);
    color: white;
    font-size: 1.1rem;
    font-family: 'Cairo', sans-serif;
    text-align: center;
    margin-bottom: 16px;
    outline: none;
    transition: border-color 0.2s;
  }

  .name-gate-card input::placeholder { color: rgba(255,255,255,0.4); }
  .name-gate-card input:focus { border-color: var(--accent); }

  .btn-enter {
    width: 100%;
    padding: 16px;
    background: linear-gradient(135deg, var(--accent), #0096c7);
    color: white;
    border: none;
    border-radius: 14px;
    font-size: 1.1rem;
    font-weight: 700;
    font-family: 'Cairo', sans-serif;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-enter:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(0,180,216,0.4); }

  /* ===== SECTIONS ===== */
  .section {
    padding: 80px 20px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
    display: block;
  }

  .section-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 900;
    color: var(--dark);
    margin-bottom: 40px;
  }

  /* ===== TABS ===== */
  .tabs-wrapper {
    background: var(--card);
    border-radius: 20px;
    box-shadow: 0 4px 30px rgba(0,0,0,0.08);
    overflow: hidden;
    margin-bottom: 40px;
  }

  .tabs-header {
    display: flex;
    background: var(--dark);
    overflow-x: auto;
  }

  .tab-btn {
    padding: 16px 24px;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.6);
    font-family: 'Cairo', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    border-bottom: 3px solid transparent;
  }

  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    background: rgba(0,180,216,0.1);
  }

  .tab-content { display: none; padding: 30px; }
  .tab-content.active { display: block; }

  /* ===== INJECTION CARDS ===== */
  .injection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .injection-card {
    background: linear-gradient(135deg, #fff, var(--light-accent));
    border: 1px solid rgba(0,180,216,0.2);
    border-radius: 18px;
    padding: 24px;
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }

  .injection-card::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 4px;
    height: 100%;
    background: var(--accent);
    border-radius: 0 18px 18px 0;
  }

  .injection-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 35px rgba(0,90,120,0.15);
  }

  .inj-icon { font-size: 2.5rem; margin-bottom: 12px; display: block; }
  .inj-title { font-size: 1.1rem; font-weight: 800; color: var(--dark); margin-bottom: 8px; }
  .inj-site { font-size: 0.8rem; color: var(--accent); font-weight: 600; margin-bottom: 10px; }
  .inj-desc { font-size: 0.88rem; color: #555; line-height: 1.7; font-family: 'Tajawal', sans-serif; }

  .expand-btn {
    margin-top: 14px;
    padding: 8px 18px;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 30px;
    font-size: 0.8rem;
    font-family: 'Cairo', sans-serif;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
  }

  .expand-btn:hover { background: var(--accent); }

  .inj-details {
    display: none;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px dashed rgba(0,180,216,0.4);
    font-size: 0.83rem;
    color: #444;
    font-family: 'Tajawal', sans-serif;
    line-height: 1.8;
  }

  .inj-details.open { display: block; animation: fadeIn 0.3s; }

  .inj-details ul { padding-right: 18px; }
  .inj-details li { margin-bottom: 6px; }

  /* ===== VITAL SIGNS ===== */
  .vital-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 18px;
    margin-bottom: 30px;
  }

  .vital-card {
    background: var(--card);
    border-radius: 18px;
    padding: 24px 20px;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    border-top: 4px solid var(--accent);
    transition: transform 0.2s;
  }

  .vital-card:hover { transform: translateY(-3px); }
  .vital-icon { font-size: 2.8rem; margin-bottom: 10px; display: block; }
  .vital-name { font-size: 1rem; font-weight: 800; color: var(--dark); margin-bottom: 6px; }
  .vital-normal { font-size: 0.85rem; color: var(--success); font-weight: 700; margin-bottom: 8px; }
  .vital-desc { font-size: 0.8rem; color: #666; line-height: 1.6; font-family: 'Tajawal', sans-serif; }

  .vital-interactive {
    background: var(--card);
    border-radius: 18px;
    padding: 30px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    margin-top: 20px;
  }

  .vital-interactive h3 {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 20px;
  }

  .vital-input-row {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 16px;
  }

  .vital-input-group {
    flex: 1;
    min-width: 160px;
  }

  .vital-input-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 6px;
  }

  .vital-input-group input {
    width: 100%;
    padding: 12px 14px;
    border: 2px solid #e0e8ed;
    border-radius: 10px;
    font-size: 1rem;
    font-family: 'Cairo', sans-serif;
    outline: none;
    transition: border-color 0.2s;
  }

  .vital-input-group input:focus { border-color: var(--accent); }

  .vital-result {
    padding: 16px;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: 'Tajawal', sans-serif;
    display: none;
  }

  .vital-result.normal { background: rgba(42,157,143,0.15); color: var(--success); border: 1px solid var(--success); }
  .vital-result.abnormal { background: rgba(231,111,81,0.15); color: var(--danger); border: 1px solid var(--danger); }

  /* ===== QUIZ ===== */
  .quiz-container {
    background: var(--card);
    border-radius: 20px;
    padding: 35px;
    box-shadow: 0 4px 30px rgba(0,0,0,0.08);
  }

  .quiz-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .quiz-topic-btn {
    padding: 8px 18px;
    border: 2px solid var(--primary);
    background: transparent;
    color: var(--primary);
    border-radius: 30px;
    font-size: 0.8rem;
    font-family: 'Cairo', sans-serif;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .quiz-topic-btn.active, .quiz-topic-btn:hover {
    background: var(--primary);
    color: white;
  }

  .quiz-progress-bar {
    height: 6px;
    background: #e0e8ed;
    border-radius: 3px;
    margin-bottom: 28px;
    overflow: hidden;
  }

  .quiz-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--success));
    border-radius: 3px;
    transition: width 0.4s ease;
  }

  .quiz-score-badge {
    background: var(--light-accent);
    color: var(--primary);
    padding: 6px 16px;
    border-radius: 30px;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .question-text {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 22px;
    line-height: 1.6;
  }

  .options-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .option-btn {
    padding: 14px 20px;
    border: 2px solid #e0e8ed;
    background: #fafcfe;
    border-radius: 12px;
    text-align: right;
    font-size: 0.95rem;
    font-family: 'Cairo', sans-serif;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    color: var(--text);
  }

  .option-btn:hover:not(:disabled) {
    border-color: var(--accent);
    background: var(--light-accent);
  }

  .option-btn.correct { background: rgba(42,157,143,0.15); border-color: var(--success); color: var(--success); }
  .option-btn.wrong { background: rgba(231,111,81,0.15); border-color: var(--danger); color: var(--danger); }

  .quiz-feedback {
    margin-top: 16px;
    padding: 14px;
    border-radius: 12px;
    font-size: 0.9rem;
    font-family: 'Tajawal', sans-serif;
    display: none;
    line-height: 1.6;
  }

  .quiz-feedback.show { display: block; }
  .quiz-feedback.correct { background: rgba(42,157,143,0.1); color: var(--success); }
  .quiz-feedback.wrong { background: rgba(231,111,81,0.1); color: var(--danger); }

  .btn-next {
    margin-top: 20px;
    padding: 12px 30px;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 30px;
    font-size: 0.95rem;
    font-family: 'Cairo', sans-serif;
    font-weight: 700;
    cursor: pointer;
    display: none;
    transition: all 0.2s;
  }

  .btn-next.show { display: inline-block; }
  .btn-next:hover { background: var(--accent); transform: translateY(-1px); }

  /* ===== RESULT SCREEN ===== */
  .quiz-result {
    text-align: center;
    padding: 40px 20px;
    display: none;
  }

  .quiz-result.show { display: block; animation: fadeIn 0.5s; }

  .result-emoji { font-size: 70px; margin-bottom: 16px; display: block; }
  .result-score { font-size: 3rem; font-weight: 900; color: var(--primary); }
  .result-text { font-size: 1.1rem; color: #555; margin: 10px 0 24px; font-family: 'Tajawal', sans-serif; }

  .btn-restart {
    padding: 14px 34px;
    background: linear-gradient(135deg, var(--accent), var(--primary));
    color: white;
    border: none;
    border-radius: 30px;
    font-size: 1rem;
    font-family: 'Cairo', sans-serif;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s;
  }

  .btn-restart:hover { transform: scale(1.05); }

  /* ===== LEADERBOARD ===== */
  .leaderboard-section {
    background: var(--card);
    border-radius: 20px;
    padding: 35px;
    box-shadow: 0 4px 30px rgba(0,0,0,0.08);
  }

  .leaderboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .leaderboard-title {
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--dark);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .lb-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 18px;
    border-radius: 14px;
    margin-bottom: 10px;
    transition: transform 0.2s;
    background: #fafcfe;
    border: 1px solid #e8f0f4;
  }

  .lb-row:hover { transform: translateX(-4px); }

  .lb-row.rank-1 { background: linear-gradient(135deg, #fff8e1, #fff3cd); border-color: #ffd700; }
  .lb-row.rank-2 { background: linear-gradient(135deg, #f5f5f5, #eeeeee); border-color: #b0bec5; }
  .lb-row.rank-3 { background: linear-gradient(135deg, #fff3e0, #ffe0b2); border-color: #ff9800; }

  .lb-rank {
    font-size: 1.2rem;
    font-weight: 900;
    min-width: 40px;
    text-align: center;
  }

  .rank-1 .lb-rank { color: #d4a017; }
  .rank-2 .lb-rank { color: #78909c; }
  .rank-3 .lb-rank { color: #e65100; }

  .lb-name { flex: 1; font-weight: 700; font-size: 1rem; color: var(--dark); }
  .lb-score { font-weight: 900; color: var(--primary); font-size: 1.1rem; }
  .lb-topic { font-size: 0.75rem; color: #888; font-family: 'Tajawal', sans-serif; }
  .lb-date { font-size: 0.75rem; color: #aaa; }

  .lb-empty {
    text-align: center;
    padding: 40px;
    color: #aaa;
    font-family: 'Tajawal', sans-serif;
  }

  /* ===== VIDEO ===== */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .video-card {
    background: var(--card);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transition: transform 0.25s;
  }

  .video-card:hover { transform: translateY(-4px); }

  .video-thumb {
    position: relative;
    padding-top: 56.25%;
    background: var(--dark);
    overflow: hidden;
  }

  .video-thumb iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-info { padding: 18px; }
  .video-info h4 { font-size: 1rem; font-weight: 800; color: var(--dark); margin-bottom: 6px; }
  .video-info p { font-size: 0.82rem; color: #666; font-family: 'Tajawal', sans-serif; }
  .video-tag {
    display: inline-block;
    margin-top: 10px;
    padding: 4px 12px;
    background: var(--light-accent);
    color: var(--primary);
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
  }

  /* ===== UTILITIES ===== */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .btn-check {
    margin-top: 16px;
    padding: 12px 28px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 30px;
    font-size: 0.95rem;
    font-family: 'Cairo', sans-serif;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-check:hover { background: var(--primary); }

  .badge-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 20px;
  }

  .badge {
    padding: 6px 16px;
    border-radius: 30px;
    font-size: 0.8rem;
    font-weight: 700;
    border: 1px solid;
  }

  .badge.blue { background: var(--light-accent); color: var(--primary); border-color: var(--accent); }
  .badge.red { background: rgba(231,111,81,0.1); color: var(--danger); border-color: var(--danger); }
  .badge.green { background: rgba(42,157,143,0.1); color: var(--success); border-color: var(--success); }

  footer {
    background: var(--dark);
    color: rgba(255,255,255,0.6);
    text-align: center;
    padding: 30px;
    font-family: 'Tajawal', sans-serif;
    font-size: 0.9rem;
  }

  footer span { color: var(--accent); }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 4px; }

  @media(max-width: 600px) {
    nav { padding: 14px 16px; }
    .nav-links { display: none; }
    .section { padding: 50px 16px; }
    .quiz-container { padding: 20px; }
    .leaderboard-section { padding: 20px; }
  }

  .section-divider {
    border: none;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    margin: 0 auto;
    max-width: 300px;
    margin-bottom: 60px;
  }

  /* Flash message */
  .flash {
    position: fixed;
    top: 80px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--success);
    color: white;
    padding: 12px 28px;
    border-radius: 30px;
    font-size: 0.95rem;
    font-family: 'Cairo', sans-serif;
    font-weight: 700;
    z-index: 500;
    display: none;
    animation: fadeIn 0.3s;
  }
</style>
</head>
<body>

<!-- NAME GATE -->
<div id="nameGate">
  <div class="name-gate-card">
    <span class="name-gate-icon">🏥</span>
